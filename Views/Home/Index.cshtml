@model IEnumerable<PortalCampanas.Models.Campana>

@{
    ViewData["Title"] = "Listado de Campañas";
}

<h2 class="mb-4">Portal de Campañas Comerciales</h2>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>Categoría</th>
            <th>Estado</th>
            <th>Canal</th>
            <th>Descuento</th>
            <th>Fechas</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.Categoria</td>
                <td>
                    <span class="badge @(item.Estado == "Vigente" ? "bg-success" : item.Estado == "Próxima" ? "bg-primary" : "bg-secondary")">
                        @item.Estado
                    </span>
                </td>
                <td>@item.Canal</td>
                <td>@item.DescuentoPct%</td>
                <td>@item.FechaInicio.ToShortDateString() - @item.FechaFin.ToShortDateString()</td>
                <td>
                    <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-info btn-sm">Ver detalle</a>
                </td>
            </tr>
        }
    </tbody>
</table>