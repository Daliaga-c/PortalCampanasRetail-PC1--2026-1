@model IEnumerable<PortalCampanas.Models.Campana>

@{
    ViewData["Title"] = "Listado de Campañas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary">Campañas Comerciales</h2>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Nombre</th>
                        <th>Categoría</th>
                        <th>Estado</th>
                        <th>Canal</th>
                        <th>Descuento</th>
                        <th>Fechas</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">@item.Nombre</td>
                                <td>@item.Categoria</td>
                                <td>
                                    <span class="badge @(item.Estado == "Vigente" ? "bg-success" : item.Estado == "Próxima" ? "bg-primary" : "bg-secondary")">
                                        @item.Estado
                                    </span>
                                </td>
                                <td>@item.Canal</td>
                                <td class="text-danger fw-bold">@item.DescuentoPct%</td>
                                <td class="small">
                                    @item.FechaInicio.ToString("dd/MM/yyyy") - @item.FechaFin.ToString("dd/MM/yyyy")
                                </td>
                                <td class="text-center">
                                    <a asp-controller="Campanas" asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">
                                        Ver detalle
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">No hay campañas disponibles.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>